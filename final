<script>
const observer = new IntersectionObserver((entries) => {
  entries.forEach(el => { if (el.isIntersecting) el.target.classList.add('visible'); });
}, { threshold: 0.12 });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

const nav = document.querySelector('nav');
window.addEventListener('scroll', () => {
  nav.style.background = window.scrollY > 60 ? 'rgba(8,8,20,0.97)' : 'rgba(8,8,20,0.85)';
});

/* ===================== INTERACTIVE MAP ===================== */
const canvas = document.getElementById('mapCanvas');
const ctx = canvas.getContext('2d');
const tooltip = document.getElementById('mapTooltip');

const CORAL = '#E8593C', BLUE = '#3B8BD4', AMBER = '#F9A825', GREEN = '#2DD66D';

let scale = 1, offsetX = 0, offsetY = 0;
let isDragging = false, dragStart = { x:0, y:0 };
let hoveredPin = null, activeFilter = 'all', animFrame = 0;

const PINS = [
  { wx:0.22, wy:0.28, color:CORAL, icon:'!', type:'urgence',  label:'Panne electrique',     sub:'il y a 3 min - 280m',  r:14 },
  { wx:0.55, wy:0.18, color:BLUE,  icon:'+', type:'bricolage',label:'Meuble a monter',       sub:'il y a 12 min - 450m', r:13 },
  { wx:0.70, wy:0.42, color:AMBER, icon:'*', type:'senior',   label:'Courses et compagnie',  sub:'il y a 20 min - 600m', r:13 },
  { wx:0.30, wy:0.60, color:GREEN, icon:'A', type:'mobilite', label:'Rendez-vous medical',   sub:'il y a 35 min - 720m', r:12 },
  { wx:0.72, wy:0.70, color:BLUE,  icon:'+', type:'bricolage',label:'Robinetterie a reparer',sub:'il y a 48 min - 900m', r:12 },
  { wx:0.15, wy:0.75, color:CORAL, icon:'!', type:'urgence',  label:'Chute personne agee',   sub:'il y a 55 min - 1.1km',r:11 },
  { wx:0.88, wy:0.30, color:AMBER, icon:'*', type:'senior',   label:'Visite convivialite',   sub:'il y a 1h - 1.3km',   r:11 },
  { wx:0.48, wy:0.78, color:GREEN, icon:'A', type:'mobilite', label:'Aide administrative',   sub:'il y a 1h15 - 1.5km', r:10 },
];

const YOU = { wx:0.44, wy:0.52 };

function resize() {
  const w = canvas.parentElement.clientWidth;
  const h = canvas.parentElement.clientHeight;
  canvas.width = w; canvas.height = h;
}

function wts(wx, wy) {
  return { x: wx * canvas.width * scale + offsetX, y: wy * canvas.height * scale + offsetY };
}

function drawGrid() {
  const step = 40 * scale;
  const sx = offsetX % step, sy = offsetY % step;
  ctx.strokeStyle = 'rgba(100,120,200,0.07)'; ctx.lineWidth = 0.8;
  for (let x = sx; x < canvas.width; x += step) { ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,canvas.height); ctx.stroke(); }
  for (let y = sy; y < canvas.height; y += step) { ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(canvas.width,y); ctx.stroke(); }
}

function drawRoads() {
  const roads = [
    [[0,0.52],[1,0.52]],[[0.44,0],[0.44,1]],
    [[0,0.28],[0.44,0.28]],[[0.44,0.28],[1,0.20]],
    [[0,0.72],[0.44,0.72]],[[0.44,0.72],[1,0.78]],
    [[0.22,0],[0.22,0.52]],[[0.22,0.52],[0.22,1]],
    [[0.68,0],[0.68,0.52]],[[0.68,0.52],[0.68,1]],
  ];
  roads.forEach(rd => {
    const s1 = wts(rd[0][0],rd[0][1]), s2 = wts(rd[1][0],rd[1][1]);
    ctx.strokeStyle='rgba(140,160,220,0.14)'; ctx.lineWidth=4*scale;
    ctx.beginPath(); ctx.moveTo(s1.x,s1.y); ctx.lineTo(s2.x,s2.y); ctx.stroke();
  });
}

function drawBlocks() {
  const blocks = [
    [0.05,0.05,0.12,0.08],[0.20,0.08,0.18,0.06],[0.45,0.05,0.10,0.09],
    [0.62,0.08,0.14,0.07],[0.82,0.06,0.13,0.08],[0.05,0.22,0.08,0.14],
    [0.34,0.28,0.12,0.10],[0.55,0.30,0.16,0.12],[0.78,0.48,0.10,0.16],
    [0.10,0.40,0.14,0.10],[0.05,0.62,0.10,0.14],[0.28,0.72,0.16,0.08],
    [0.52,0.68,0.12,0.12],[0.72,0.82,0.20,0.10],[0.85,0.62,0.12,0.14],
  ];
  ctx.fillStyle='rgba(20,20,50,0.6)'; ctx.strokeStyle='rgba(100,120,200,0.12)'; ctx.lineWidth=0.8;
  blocks.forEach(b => {
    const s=wts(b[0],b[1]), w=b[2]*canvas.width*scale, h=b[3]*canvas.height*scale;
    ctx.beginPath(); ctx.roundRect(s.x,s.y,w,h,2*scale); ctx.fill(); ctx.stroke();
  });
}

function drawWeb() {
  const you = wts(YOU.wx, YOU.wy);
  PINS.filter(p => activeFilter==='all'||p.type===activeFilter).forEach(p => {
    const ps = wts(p.wx,p.wy);
    ctx.strokeStyle=p.color+'22'; ctx.lineWidth=0.8;
    ctx.beginPath(); ctx.moveTo(you.x,you.y); ctx.lineTo(ps.x,ps.y); ctx.stroke();
  });
  [0.12,0.22,0.34].forEach(r => {
    ctx.strokeStyle='rgba(232,89,60,0.07)'; ctx.lineWidth=0.8;
    ctx.beginPath(); ctx.arc(you.x,you.y,r*canvas.width*scale,0,Math.PI*2); ctx.stroke();
  });
}

function drawPin(p, f) {
  const {x,y} = wts(p.wx,p.wy);
  const r = p.r*scale, isH = hoveredPin===p;
  const pulse = isH ? 1+Math.sin(f*0.08)*0.12 : 1;
  const a = 0.15+Math.abs(Math.sin(f*0.04+p.wx*5))*0.1;
  ctx.beginPath(); ctx.arc(x,y,r*1.7*pulse,0,Math.PI*2);
  ctx.fillStyle=p.color+Math.round(a*255).toString(16).padStart(2,'0'); ctx.fill();
  ctx.beginPath(); ctx.arc(x,y,r,0,Math.PI*2); ctx.fillStyle=p.color; ctx.fill();
  if(isH){ ctx.beginPath(); ctx.arc(x,y,r+3*scale,0,Math.PI*2); ctx.strokeStyle=p.color; ctx.lineWidth=1.5; ctx.stroke(); }
  ctx.fillStyle='#fff'; ctx.font=`bold ${Math.max(8,9*scale)}px monospace`;
  ctx.textAlign='center'; ctx.textBaseline='middle'; ctx.fillText(p.icon,x,y);
}

function drawYou(f) {
  const {x,y} = wts(YOU.wx,YOU.wy);
  const r=10*scale, pulse=0.5+Math.abs(Math.sin(f*0.05))*0.5;
  ctx.beginPath(); ctx.arc(x,y,r*2.5*(1+pulse*0.3),0,Math.PI*2);
  ctx.fillStyle=`rgba(232,89,60,${0.06+pulse*0.04})`; ctx.fill();
  ctx.beginPath(); ctx.arc(x,y,r,0,Math.PI*2); ctx.fillStyle=CORAL; ctx.fill();
  ctx.beginPath(); ctx.arc(x,y,r,0,Math.PI*2); ctx.strokeStyle='#fff'; ctx.lineWidth=2*scale; ctx.stroke();
  ctx.fillStyle='#fff'; ctx.font=`bold ${Math.max(7,8*scale)}px sans-serif`;
  ctx.textAlign='center'; ctx.textBaseline='middle'; ctx.fillText('*',x,y);
  ctx.fillStyle='rgba(232,89,60,0.9)'; ctx.font=`${Math.max(9,9*scale)}px 'DM Sans',sans-serif`;
  ctx.fillText('Vous',x,y+r+10*scale);
}

function render() {
  animFrame++;
  ctx.clearRect(0,0,canvas.width,canvas.height);
  ctx.fillStyle='#0d0d1c'; ctx.fillRect(0,0,canvas.width,canvas.height);
  drawGrid(); drawRoads(); drawBlocks(); drawWeb();
  PINS.forEach(p => { if(activeFilter==='all'||p.type===activeFilter) drawPin(p,animFrame); });
  drawYou(animFrame);
  requestAnimationFrame(render);
}

function getPinAt(mx,my) {
  for(const p of PINS) {
    if(activeFilter!=='all'&&p.type!==activeFilter) continue;
    const {x,y}=wts(p.wx,p.wy);
    if(Math.hypot(mx-x,my-y)<p.r*scale*1.8) return p;
  }
  return null;
}

canvas.addEventListener('mousemove', e => {
  const rect=canvas.getBoundingClientRect(), mx=e.clientX-rect.left, my=e.clientY-rect.top;
  if(isDragging){ offsetX+=mx-dragStart.x; offsetY+=my-dragStart.y; dragStart={x:mx,y:my}; return; }
  const pin=getPinAt(mx,my); hoveredPin=pin;
  if(pin){
    canvas.style.cursor='pointer';
    const {x,y}=wts(pin.wx,pin.wy);
    tooltip.style.display='block';
    tooltip.style.left=(x>canvas.width*0.7?x-170:x+20)+'px';
    tooltip.style.top=(y-30)+'px';
    document.getElementById('ttTitle').innerHTML=`<span class="tt-dot" style="background:${pin.color}"></span>${pin.label}`;
    document.getElementById('ttSub').textContent=pin.sub;
  } else {
    canvas.style.cursor='grab'; tooltip.style.display='none';
  }
});

canvas.addEventListener('mouseleave',()=>{ isDragging=false; hoveredPin=null; tooltip.style.display='none'; });
canvas.addEventListener('mousedown', e=>{ const r=canvas.getBoundingClientRect(); dragStart={x:e.clientX-r.left,y:e.clientY-r.top}; isDragging=true; canvas.style.cursor='grabbing'; });
canvas.addEventListener('mouseup',()=>{ isDragging=false; canvas.style.cursor=hoveredPin?'pointer':'grab'; });
canvas.addEventListener('wheel', e=>{
  e.preventDefault();
  const d=e.deltaY>0?0.9:1.1, r=canvas.getBoundingClientRect(), mx=e.clientX-r.left, my=e.clientY-r.top;
  offsetX=mx-(mx-offsetX)*d; offsetY=my-(my-offsetY)*d;
  scale=Math.max(0.5,Math.min(3,scale*d));
},{ passive:false });

document.getElementById('zoomIn').addEventListener('click',()=>{ const cx=canvas.width/2,cy=canvas.height/2; offsetX=cx-(cx-offsetX)*1.25; offsetY=cy-(cy-offsetY)*1.25; scale=Math.min(3,scale*1.25); });
document.getElementById('zoomOut').addEventListener('click',()=>{ const cx=canvas.width/2,cy=canvas.height/2; offsetX=cx-(cx-offsetX)*0.8; offsetY=cy-(cy-offsetY)*0.8; scale=Math.max(0.5,scale*0.8); });
document.getElementById('resetMap').addEventListener('click',()=>{ scale=1; offsetX=0; offsetY=0; });

document.querySelectorAll('.filter-chip').forEach(chip=>{
  chip.addEventListener('click',()=>{
    document.querySelectorAll('.filter-chip').forEach(c=>c.classList.remove('active'));
    chip.classList.add('active'); activeFilter=chip.dataset.filter;
  });
});

document.querySelectorAll('.map-request-card').forEach((card,i)=>{
  card.addEventListener('click',()=>{
    const p=PINS[i]; if(!p) return;
    offsetX=0.5*canvas.width-p.wx*canvas.width*1.4;
    offsetY=0.5*canvas.height-p.wy*canvas.height*1.4;
    scale=1.4; hoveredPin=p;
  });
});

window.addEventListener('resize',()=>resize());
resize();
render();
</script>
</body>

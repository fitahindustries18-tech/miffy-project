<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MIFFY - Entraide Citoyenne 24/7</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --coral: #E8593C;
    --coral-dark: #C0341A;
    --dark: #080814;
    --dark2: #0d0d1c;
    --card: #0f0f22;
    --white: #ffffff;
    --grey: #9090b0;
    --grey-light: #c0c0d8;
    --blue: #3B8BD4;
    --green: #2DD66D;
    --amber: #F9A825;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { background: var(--dark); color: var(--white); font-family: 'DM Sans', sans-serif; font-weight: 300; line-height: 1.7; overflow-x: hidden; }
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--dark); }
  ::-webkit-scrollbar-thumb { background: var(--coral); border-radius: 3px; }
  .display { font-family: 'Bebas Neue', sans-serif; letter-spacing: 0.04em; line-height: 0.95; }
  h2.section-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.8rem, 6vw, 5rem); letter-spacing: 0.04em; line-height: 0.95; }
  .grid-bg { background-image: linear-gradient(rgba(232,89,60,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(232,89,60,0.04) 1px, transparent 1px); background-size: 60px 60px; }
  .web-canvas { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; overflow: visible; }

  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 1.2rem 5vw; display: flex; align-items: center; justify-content: space-between; background: rgba(8,8,20,0.85); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(232,89,60,0.12); transition: background 0.3s; }
  .nav-logo { font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 0.1em; color: var(--white); text-decoration: none; }
  .nav-logo span { color: var(--coral); }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a { color: var(--grey); text-decoration: none; font-size: 0.875rem; font-weight: 400; letter-spacing: 0.05em; text-transform: uppercase; transition: color 0.2s; }
  .nav-links a:hover { color: var(--coral); }
  .nav-cta { background: var(--coral) !important; color: var(--white) !important; padding: 0.5rem 1.25rem; border-radius: 2px; font-weight: 500 !important; }
  .nav-cta:hover { background: var(--coral-dark) !important; }

  #hero { position: relative; min-height: 100vh; display: flex; align-items: center; overflow: hidden; padding: 8rem 5vw 5rem; }
  .hero-inner { position: relative; z-index: 2; max-width: 700px; }
  .hero-badge { display: inline-flex; align-items: center; gap: 0.5rem; background: rgba(232,89,60,0.12); border: 1px solid rgba(232,89,60,0.3); border-radius: 2px; padding: 0.35rem 0.9rem; font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--coral); margin-bottom: 2rem; animation: fadeInDown 0.8s ease forwards; }
  .hero-badge::before { content: ''; width: 6px; height: 6px; background: var(--green); border-radius: 50%; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{box-shadow:0 0 0 0 rgba(45,214,109,0.6)}50%{box-shadow:0 0 0 6px rgba(45,214,109,0)} }
  .hero-title { font-size: clamp(5rem, 14vw, 12rem); line-height: 0.92; margin-bottom: 1.5rem; animation: fadeInUp 0.8s ease 0.1s both; }
  .hero-title .accent { color: var(--coral); }
  .hero-sub { font-size: clamp(1.1rem, 2vw, 1.35rem); color: var(--grey-light); max-width: 520px; margin-bottom: 2.5rem; animation: fadeInUp 0.8s ease 0.25s both; }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; animation: fadeInUp 0.8s ease 0.4s both; }
  .btn-primary { background: var(--coral); color: var(--white); padding: 0.85rem 2.2rem; border: none; border-radius: 2px; font-family: 'DM Sans', sans-serif; font-size: 1rem; font-weight: 500; cursor: pointer; text-decoration: none; display: inline-block; transition: background 0.2s, transform 0.15s; }
  .btn-primary:hover { background: var(--coral-dark); transform: translateY(-2px); }
  .btn-outline { background: transparent; color: var(--white); padding: 0.85rem 2.2rem; border: 1px solid rgba(255,255,255,0.2); border-radius: 2px; font-family: 'DM Sans', sans-serif; font-size: 1rem; font-weight: 400; cursor: pointer; text-decoration: none; display: inline-block; transition: border-color 0.2s, transform 0.15s, color 0.2s; }
  .btn-outline:hover { border-color: var(--coral); color: var(--coral); transform: translateY(-2px); }
  .hero-stats { position: absolute; right: 5vw; bottom: 4rem; display: flex; flex-direction: column; gap: 1.5rem; animation: fadeInRight 0.8s ease 0.5s both; }
  .stat-item { text-align: right; }
  .stat-num { font-family: 'Bebas Neue', sans-serif; font-size: 3.5rem; letter-spacing: 0.04em; line-height: 1; color: var(--coral); }
  .stat-label { font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--grey); }
  .web-line { stroke: var(--coral); stroke-width: 0.5; opacity: 0; animation: webDraw 2s ease forwards; }
  @keyframes webDraw { to { opacity: 0.12; } }
  .robot-wrap { position: absolute; right: 8vw; top: 50%; transform: translateY(-50%); animation: floatBot 4s ease-in-out infinite, fadeInRight 1s ease 0.3s both; z-index: 1; }
  @keyframes floatBot { 0%,100%{transform:translateY(-50%) translateY(0)}50%{transform:translateY(-50%) translateY(-16px)} }
  .robot-svg { width: clamp(180px, 20vw, 300px); }

  section { padding: 6rem 5vw; position: relative; }
  .section-badge { display: inline-block; font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--coral); border: 1px solid rgba(232,89,60,0.3); padding: 0.3rem 0.8rem; border-radius: 2px; margin-bottom: 1.2rem; }

  #mission { background: var(--dark2); border-top: 1px solid rgba(232,89,60,0.08); }
  .mission-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; margin-top: 3rem; }
  .mission-text p { color: var(--grey-light); font-size: 1.05rem; margin-bottom: 1.2rem; }
  .mission-text p strong { color: var(--white); font-weight: 500; }
  .mission-quote { border-left: 3px solid var(--coral); padding-left: 1.5rem; font-size: 1.25rem; color: var(--coral); font-style: italic; margin: 2rem 0; }
  .mission-pillars { display: flex; flex-direction: column; gap: 1.2rem; }
  .pillar { display: flex; align-items: flex-start; gap: 1rem; padding: 1.2rem; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 4px; transition: border-color 0.2s, transform 0.2s; }
  .pillar:hover { border-color: rgba(232,89,60,0.4); transform: translateX(4px); }
  .pillar-icon { width: 42px; height: 42px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; flex-shrink: 0; }
  .pillar h4 { font-size: 0.95rem; font-weight: 500; margin-bottom: 0.25rem; }
  .pillar p { font-size: 0.85rem; color: var(--grey); margin: 0; }

  #services { background: var(--dark); }
  .services-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3rem; }
  .services-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5px; border: 1.5px solid rgba(232,89,60,0.15); border-radius: 4px; overflow: hidden; }
  .service-card { background: var(--card); padding: 2.2rem; transition: background 0.25s; position: relative; overflow: hidden; }
  .service-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; transform: scaleX(0); transform-origin: left; transition: transform 0.3s ease; }
  .service-card:hover::before { transform: scaleX(1); }
  .service-card:hover { background: rgba(232,89,60,0.05); }
  .service-card.c1::before { background: var(--coral); }
  .service-card.c2::before { background: var(--amber); }
  .service-card.c3::before { background: var(--blue); }
  .service-card.c4::before { background: var(--green); }
  .service-icon { width: 52px; height: 52px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; margin-bottom: 1.4rem; }
  .service-card h3 { font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; letter-spacing: 0.04em; margin-bottom: 0.8rem; }
  .service-card p { font-size: 0.88rem; color: var(--grey); line-height: 1.65; }

  #how { background: var(--dark2); border-top: 1px solid rgba(232,89,60,0.08); }
  .steps-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; margin-top: 3.5rem; }
  .step { padding: 2rem 1.5rem; }
  .step-num { font-family: 'Bebas Neue', sans-serif; font-size: 4.5rem; line-height: 1; color: rgba(232,89,60,0.15); margin-bottom: 1rem; transition: color 0.3s; }
  .step:hover .step-num { color: var(--coral); }
  .step-circle { width: 44px; height: 44px; border-radius: 50%; background: var(--coral); display: flex; align-items: center; justify-content: center; font-size: 1.1rem; margin-bottom: 1.2rem; }
  .step h3 { font-weight: 500; font-size: 1rem; margin-bottom: 0.6rem; }
  .step p { font-size: 0.85rem; color: var(--grey); }

  /* MAP */
  #map { background: var(--dark); overflow: hidden; }
  .map-container { margin-top: 3rem; display: grid; grid-template-columns: 1fr 360px; gap: 2.5rem; align-items: start; }
  .map-canvas-wrap { position: relative; background: var(--dark2); border: 1px solid rgba(232,89,60,0.2); border-radius: 8px; overflow: hidden; aspect-ratio: 16/10; }
  #mapCanvas { width: 100%; height: 100%; display: block; cursor: grab; }
  #mapCanvas:active { cursor: grabbing; }
  .map-legend { position: absolute; top: 14px; left: 14px; background: rgba(8,8,20,0.88); border: 1px solid rgba(232,89,60,0.2); border-radius: 6px; padding: 10px 14px; display: flex; flex-direction: column; gap: 6px; backdrop-filter: blur(8px); }
  .map-legend-item { display: flex; align-items: center; gap: 8px; font-size: 11px; color: var(--grey-light); }
  .legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .map-controls { position: absolute; bottom: 14px; right: 14px; display: flex; flex-direction: column; gap: 4px; }
  .map-btn { width: 32px; height: 32px; background: rgba(8,8,20,0.9); border: 1px solid rgba(232,89,60,0.25); border-radius: 4px; color: var(--white); font-size: 1.1rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s; }
  .map-btn:hover { background: var(--coral); }
  .map-tooltip { position: absolute; background: rgba(8,8,20,0.96); border: 1px solid rgba(232,89,60,0.4); border-radius: 6px; padding: 8px 12px; font-size: 12px; color: var(--white); pointer-events: none; display: none; z-index: 10; min-width: 140px; backdrop-filter: blur(8px); }
  .map-tooltip .tt-title { font-weight: 500; font-size: 13px; margin-bottom: 3px; }
  .map-tooltip .tt-sub { color: var(--grey); font-size: 11px; }
  .tt-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 5px; vertical-align: middle; }
  .map-sidebar { display: flex; flex-direction: column; gap: 1rem; }
  .map-sidebar-title { font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--grey); margin-bottom: 0.3rem; }
  .map-request-card { background: var(--card); border: 1px solid rgba(255,255,255,0.06); border-radius: 6px; padding: 1rem 1.1rem; cursor: pointer; transition: border-color 0.2s, transform 0.15s; position: relative; overflow: hidden; }
  .map-request-card:hover { border-color: rgba(232,89,60,0.4); transform: translateX(3px); }
  .mrc-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
  .mrc-type { font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 500; }
  .mrc-dist { font-size: 10px; color: var(--grey); background: rgba(255,255,255,0.05); padding: 2px 7px; border-radius: 10px; }
  .mrc-title { font-size: 13px; font-weight: 500; margin-bottom: 3px; }
  .mrc-meta { font-size: 11px; color: var(--grey); }
  .map-filter-row { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 0.5rem; }
  .filter-chip { padding: 4px 12px; border-radius: 20px; font-size: 11px; border: 1px solid rgba(255,255,255,0.1); background: transparent; color: var(--grey); cursor: pointer; transition: all 0.2s; font-family: 'DM Sans', sans-serif; }
  .filter-chip.active { background: var(--coral); border-color: var(--coral); color: var(--white); }
  .filter-chip:hover { border-color: var(--coral); color: var(--coral); }

  /* CHAT */
  #chat { background: var(--dark2); border-top: 1px solid rgba(232,89,60,0.08); overflow: hidden; }
  .chat-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; margin-top: 3rem; }
  .chat-features { display: flex; flex-direction: column; gap: 1.4rem; }
  .chat-feat { display: flex; align-items: flex-start; gap: 1.1rem; padding: 1.2rem 1.4rem; background: var(--card); border: 1px solid rgba(255,255,255,0.05); border-radius: 6px; transition: border-color 0.2s, transform 0.2s; }
  .chat-feat:hover { border-color: rgba(232,89,60,0.3); transform: translateX(5px); }
  .chat-feat-icon { width: 46px; height: 46px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; flex-shrink: 0; }
  .chat-feat h4 { font-size: 0.95rem; font-weight: 500; margin-bottom: 0.3rem; }
  .chat-feat p { font-size: 0.82rem; color: var(--grey); margin: 0; line-height: 1.6; }
  .chat-mockup-wrap { position: relative; display: flex; justify-content: center; }
  .chat-phone { width: 280px; background: #111120; border-radius: 32px; border: 2px solid #1e1e35; overflow: hidden; box-shadow: 0 40px 80px rgba(0,0,0,0.7), 0 0 40px rgba(232,89,60,0.08); position: relative; z-index: 2; }
  .chat-notch { width: 70px; height: 22px; background: #0d0d1c; border-radius: 0 0 14px 14px; margin: 0 auto; display: flex; align-items: center; justify-content: center; gap: 5px; }
  .chat-notch::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: #1e1e30; border: 1px solid #2a2a3a; }
  .chat-notch::after { content: ''; width: 32px; height: 5px; border-radius: 3px; background: #1e1e30; }
  .chat-screen { background: #0c0c1e; padding: 0; min-height: 480px; display: flex; flex-direction: column; }
  .chat-topbar { display: flex; align-items: center; gap: 10px; padding: 12px 14px; border-bottom: 1px solid rgba(255,255,255,0.05); background: rgba(255,255,255,0.02); }
  .chat-avatar { width: 34px; height: 34px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 500; flex-shrink: 0; }
  .chat-contact-info { flex: 1; }
  .chat-contact-name { font-size: 12px; font-weight: 500; color: var(--white); }
  .chat-contact-status { font-size: 10px; color: var(--green); display: flex; align-items: center; gap: 4px; }
  .chat-contact-status::before { content: ''; width: 5px; height: 5px; background: var(--green); border-radius: 50%; }
  .chat-messages { flex: 1; padding: 14px; display: flex; flex-direction: column; gap: 10px; overflow: hidden; }
  .chat-date { text-align: center; font-size: 9px; color: rgba(255,255,255,0.25); letter-spacing: 0.1em; margin: 4px 0; }
  .msg { display: flex; align-items: flex-end; gap: 7px; }
  .msg.sent { flex-direction: row-reverse; }
  .msg-avatar { width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.6rem; font-weight: 600; flex-shrink: 0; }
  .msg-bubble { padding: 8px 11px; border-radius: 14px; font-size: 11px; line-height: 1.45; max-width: 160px; color: var(--white); }
  .msg.recv .msg-bubble { background: rgba(255,255,255,0.07); border-bottom-left-radius: 4px; }
  .msg.sent .msg-bubble { background: var(--coral); border-bottom-right-radius: 4px; }
  .msg-time { font-size: 9px; color: rgba(255,255,255,0.25); margin-top: 2px; display: block; }
  .msg-wrap { display: flex; flex-direction: column; }
  .msg.sent .msg-wrap { align-items: flex-end; }
  .typing-bubble { display: flex; align-items: center; gap: 7px; animation: fadeInUp 0.4s ease; }
  .typing-dots { background: rgba(255,255,255,0.07); border-radius: 14px; border-bottom-left-radius: 4px; padding: 10px 14px; display: flex; gap: 4px; align-items: center; }
  .typing-dots span { width: 5px; height: 5px; background: rgba(255,255,255,0.4); border-radius: 50%; display: block; animation: typingBounce 1.2s ease-in-out infinite; }
  .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
  .typing-dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes typingBounce { 0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-5px)} }
  .chat-input-bar { display: flex; align-items: center; gap: 8px; padding: 10px 12px; border-top: 1px solid rgba(255,255,255,0.05); background: rgba(255,255,255,0.02); }
  .chat-input-field { flex: 1; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08); border-radius: 20px; padding: 7px 13px; font-size: 11px; color: rgba(255,255,255,0.4); font-family: 'DM Sans', sans-serif; pointer-events: none; }
  .chat-send-btn { width: 30px; height: 30px; background: var(--coral); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 0.9rem; }
  .chat-navbar { display: flex; justify-content: space-around; padding: 8px 0 12px; border-top: 1px solid rgba(255,255,255,0.05); }
  .cnav-item { display: flex; flex-direction: column; align-items: center; gap: 3px; font-size: 9px; color: rgba(255,255,255,0.3); }
  .cnav-item.active { color: var(--coral); }
  .cnav-icon { font-size: 15px; position: relative; }
  .chat-badge-count { position: absolute; top: -3px; right: -3px; width: 14px; height: 14px; background: var(--coral); border-radius: 50%; font-size: 8px; color: white; display: flex; align-items: center; justify-content: center; font-weight: 600; }
  .notification-float { position: absolute; top: 40px; right: -55px; background: rgba(15,15,34,0.95); border: 1px solid rgba(232,89,60,0.3); border-radius: 10px; padding: 10px 14px; width: 190px; display: flex; align-items: center; gap: 10px; animation: floatNotif 3s ease-in-out infinite; z-index: 3; backdrop-filter: blur(8px); }
  @keyframes floatNotif { 0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)} }
  .notif-icon { width: 32px; height: 32px; background: rgba(45,214,109,0.15); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 1rem; flex-shrink: 0; }
  .notif-text { font-size: 10px; color: var(--white); line-height: 1.4; }
  .notif-text strong { color: var(--green); display: block; font-size: 11px; }
  .chat-web-deco { position: absolute; right: -30px; top: 30px; width: 180px; opacity: 0.06; pointer-events: none; z-index: 0; }

  #security { background: var(--dark); border-top: 1px solid rgba(232,89,60,0.08); }
  .security-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 3rem; }
  .sec-card { padding: 1.8rem; background: var(--card); border: 1px solid rgba(255,255,255,0.05); border-radius: 4px; transition: border-color 0.2s, transform 0.2s; }
  .sec-card:hover { border-color: rgba(232,89,60,0.35); transform: translateY(-4px); }
  .sec-card-icon { font-size: 1.8rem; margin-bottom: 1rem; }
  .sec-card h4 { font-weight: 500; font-size: 0.95rem; margin-bottom: 0.5rem; }
  .sec-card p { font-size: 0.82rem; color: var(--grey); line-height: 1.6; margin: 0; }

  #pricing { background: var(--dark2); border-top: 1px solid rgba(232,89,60,0.08); }
  .pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 3.5rem; }
  .price-card { padding: 2.2rem; background: var(--card); border: 1px solid rgba(255,255,255,0.06); border-radius: 4px; text-align: center; position: relative; transition: transform 0.25s; }
  .price-card:hover { transform: translateY(-6px); }
  .price-card.featured { border-color: var(--coral); background: rgba(232,89,60,0.06); }
  .featured-badge { position: absolute; top: -1px; left: 50%; transform: translateX(-50%); background: var(--coral); color: var(--white); font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; padding: 0.25rem 1rem; border-radius: 0 0 4px 4px; }
  .price-name { font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; letter-spacing: 0.06em; margin-bottom: 0.5rem; margin-top: 0.5rem; }
  .price-amount { font-family: 'Bebas Neue', sans-serif; font-size: 4rem; letter-spacing: 0.02em; line-height: 1; color: var(--coral); margin: 1.2rem 0 0.3rem; }
  .price-period { font-size: 0.8rem; color: var(--grey); margin-bottom: 1.8rem; }
  .price-features { list-style: none; text-align: left; margin-bottom: 2rem; }
  .price-features li { font-size: 0.85rem; color: var(--grey-light); padding: 0.45rem 0; border-bottom: 1px solid rgba(255,255,255,0.04); display: flex; align-items: center; gap: 0.6rem; }
  .price-features li::before { content: ''; width: 6px; height: 6px; background: var(--coral); border-radius: 50%; flex-shrink: 0; }
  .btn-plan { width: 100%; padding: 0.85rem; border-radius: 2px; font-family: 'DM Sans', sans-serif; font-size: 0.9rem; font-weight: 500; cursor: pointer; border: 1px solid rgba(232,89,60,0.4); background: transparent; color: var(--coral); transition: background 0.2s, color 0.2s; }
  .btn-plan:hover, .price-card.featured .btn-plan { background: var(--coral); color: var(--white); }

